DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
JWT_SECRET="change-me"

# Local face-api.js model directory used for face registration and attendance.
FACE_API_MODEL_DIR="./models"
FACE_DETECTION_MIN_CONFIDENCE="0.5"
EMBEDDING_VECTOR_SIZE="128"

# Gemini RAG assistant
GEN_AI_API_KEY="your-gemini-api-key"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
GEMINI_GENERATION_MODEL="gemini-2.5-flash"
